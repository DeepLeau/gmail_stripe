# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks — créer endpoint puis récupérer le signing secret
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publishable champ)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_START_PRICE_ID — https://dashboard.stripe.com/products — créer un Price pour le plan Start (10€/mois)
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — https://dashboard.stripe.com/products — créer un Price pour le plan Scale (29€/mois)
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — https://dashboard.stripe.com/products — créer un Price pour le plan Team (59€/mois)
STRIPE_TEAM_PRICE_ID=
# NEXT_PUBLIC_BASE_URL — URL de base du site (ex: http://localhost:3000 en dev)
NEXT_PUBLIC_BASE_URL=