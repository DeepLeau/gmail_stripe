
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → choisir endpoint URL et Copier le secret de signature
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER — https://dashboard.stripe.com/products → créer 3 Price ID mensuels recurring
STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH — https://dashboard.stripe.com/products
STRIPE_PRICE_GROWTH=
# STRIPE_PRICE_PRO — https://dashboard.stripe.com/products
STRIPE_PRICE_PRO=
# NEXT_PUBLIC_APP_URL — URL de base de l'app (http://localhost:3000 en dev)
NEXT_PUBLIC_APP_URL=