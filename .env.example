
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → ajouter endpoint /api/webhook
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé pk_live_... ou pk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_START — Dashboard Stripe → Products → Start product → Pricing → copier Price ID (price_... )
STRIPE_PRICE_START=
# STRIPE_PRICE_SCALE — Dashboard Stripe → Products → Scale product → Pricing → copier Price ID
STRIPE_PRICE_SCALE=
# STRIPE_PRICE_TEAM — Dashboard Stripe → Products → Team product → Pricing → copier Price ID
STRIPE_PRICE_TEAM=
# CRON_SECRET — Générer: openssl rand -hex 32
CRON_SECRET=