
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks — créer un webhook pointant vers /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_START — Dashboard Stripe → Products → créer 3 produits subscription avec prix mensuel
STRIPE_PRICE_ID_START=
# STRIPE_PRICE_ID_SCALE — Dashboard Stripe → Products
STRIPE_PRICE_ID_SCALE=
# STRIPE_PRICE_ID_TEAM — Dashboard Stripe → Products
STRIPE_PRICE_ID_TEAM=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — Variable d'environnement serveur (ex: http://localhost:3000 en dev)
NEXT_PUBLIC_BASE_URL=