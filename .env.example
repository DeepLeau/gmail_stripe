
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_START — Stripe Dashboard > Products > Start plan > Price ID
STRIPE_PRICE_START=
# STRIPE_PRICE_SCALE — Stripe Dashboard > Products > Scale plan > Price ID
STRIPE_PRICE_SCALE=
# STRIPE_PRICE_TEAM — Stripe Dashboard > Products > Team plan > Price ID
STRIPE_PRICE_TEAM=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (publishable test/live key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — Your app URL (http://localhost:3000 for dev)
NEXT_PUBLIC_BASE_URL=