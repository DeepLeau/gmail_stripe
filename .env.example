# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_STARTER_PRICE_ID — https://dashboard.stripe.com/products — créer un produit mensuel Starter à 9€ et coller le price_id
STRIPE_STARTER_PRICE_ID=
# STRIPE_GROWTH_PRICE_ID — https://dashboard.stripe.com/products — créer un produit mensuel Growth à 29€ et coller le price_id
STRIPE_GROWTH_PRICE_ID=
# STRIPE_PRO_PRICE_ID — https://dashboard.stripe.com/products — créer un produit mensuel Pro à 79€ et coller le price_id
STRIPE_PRO_PRICE_ID=
# NEXT_PUBLIC_BASE_URL — https://dashboard.vercel.com — Your deployment URL, ou http://localhost:3000 pour dev
NEXT_PUBLIC_BASE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY — utilisé côté serveur uniquement (webhooks, RPC) — JAMAIS exposé côté client
SUPABASE_SERVICE_ROLE_KEY=
