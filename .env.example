
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_APP_URL — http://localhost:3000 (dev), URL de production (prod)
NEXT_PUBLIC_APP_URL=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_START_PRICE_ID — https://dashboard.stripe.com/products → créer produit Start 10€/mois → copier price_id (prix en centimes : 1000)
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — https://dashboard.stripe.com/products → créer produit Scale 39€/mois → copier price_id (prix en centimes : 3900)
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — https://dashboard.stripe.com/products → créer produit Team 79€/mois → copier price_id (prix en centimes : 7900)
STRIPE_TEAM_PRICE_ID=