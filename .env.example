
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_PRICE_STARTER — Créer un produit Subscription dans Stripe Dashboard → Produits → ajouter Price par plan → copier le Price ID
STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH — Créer un produit Subscription dans Stripe Dashboard → Produits → ajouter Price par plan → copier le Price ID
STRIPE_PRICE_GROWTH=
# STRIPE_PRICE_PRO — Créer un produit Subscription dans Stripe Dashboard → Produits → ajouter Price par plan → copier le Price ID
STRIPE_PRICE_PRO=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → ajouter endpoint pointant vers /api/webhook/stripe → écouter checkout.session.completed et invoice.payment_succeeded → copier signing secret
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_BASE_URL — URL de production (ex: https://monapp.com) utilisée pour success_url/cancel_url. En local : http://localhost:3000
NEXT_PUBLIC_BASE_URL=