
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → endpoint URL → Signing secret
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (publishable test/live key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — Variable d'environnement Vercel ou config deploy (ex: https://myapp.vercel.app)
NEXT_PUBLIC_BASE_URL=
# Price ID Stripe pour le plan Start — https://dashboard.stripe.com/products
STRIPE_START_PRICE_ID=
# Price ID Stripe pour le plan Scale — https://dashboard.stripe.com/products
STRIPE_SCALE_PRICE_ID=
# Price ID Stripe pour le plan Team — https://dashboard.stripe.com/products
STRIPE_TEAM_PRICE_ID=
