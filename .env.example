
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# STRIPE_STARTER_PRICE_ID — Dashboard Stripe > Products > Starter > copy price_id
STRIPE_STARTER_PRICE_ID=
# STRIPE_GROWTH_PRICE_ID — Dashboard Stripe > Products > Growth > copy price_id
STRIPE_GROWTH_PRICE_ID=
# STRIPE_PRO_PRICE_ID — Dashboard Stripe > Products > Pro > copy price_id
STRIPE_PRO_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (test/publicable)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — http://localhost:3000 en dev, URL prod en production
NEXT_PUBLIC_BASE_URL=