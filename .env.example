
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_START — Dashboard Stripe > Products > Start plan > Price ID
STRIPE_PRICE_START=
# STRIPE_PRICE_SCALE — Dashboard Stripe > Products > Scale plan > Price ID
STRIPE_PRICE_SCALE=
# STRIPE_PRICE_TEAM — Dashboard Stripe > Products > Team plan > Price ID
STRIPE_PRICE_TEAM=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — Configuration environment variable (votre domaine)
NEXT_PUBLIC_BASE_URL=