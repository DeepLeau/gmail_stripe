# Supabase — récupère ces valeurs sur https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe — récupère les Price IDs sur https://dashboard.stripe.com/products
NEXT_PUBLIC_STRIPE_START_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_SCALE_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# PostHog Analytics — récupère ta clé sur https://eu.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_YOUR_PROJECT_KEY_HERE
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
