
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys (clé secrète)
STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publique)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_START_PRICE_ID — Dashboard Stripe → Products → créer produit Start 10€/mois → copier Price ID
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — Dashboard Stripe → Products → créer produit Scale 39€/mois → copier Price ID
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — Dashboard Stripe → Products → créer produit Team 79€/mois → copier Price ID
STRIPE_TEAM_PRICE_ID=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → ajouter endpoint /api/webhooks/stripe → copier signing secret
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_BASE_URL — https://dashboard.stripe.com/webhooks → set to your app URL (e.g. http://localhost:3000 in dev)
NEXT_PUBLIC_BASE_URL=