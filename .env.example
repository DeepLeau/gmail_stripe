
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → choosing endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_START — https://dashboard.stripe.com/products → prix du plan Start
STRIPE_PRICE_START=
# STRIPE_PRICE_SCALE — https://dashboard.stripe.com/products → prix du plan Scale
STRIPE_PRICE_SCALE=
# STRIPE_PRICE_TEAM — https://dashboard.stripe.com/products → prix du plan Team
STRIPE_PRICE_TEAM=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys → mode test/live publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — http://localhost:3000 en local, URL de prod en production
NEXT_PUBLIC_BASE_URL=