
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks — créer un endpoint et récupérer le secret de signature
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_STARTER — Créer le produit/price Starter 9€/mois dans Stripe Dashboard
STRIPE_PRICE_ID_STARTER=
# STRIPE_PRICE_ID_GROWTH — Créer le produit/price Growth 29€/mois dans Stripe Dashboard
STRIPE_PRICE_ID_GROWTH=
# STRIPE_PRICE_ID_PRO — Créer le produit/price Pro 79€/mois dans Stripe Dashboard
STRIPE_PRICE_ID_PRO=
# STRIPE_START_PRICE_ID — price_id Stripe pour le plan start
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — price_id Stripe pour le plan scale
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — price_id Stripe pour le plan team
STRIPE_TEAM_PRICE_ID=
# CRON_SECRET — Générer une chaîne aléatoire sécurisée pour sécuriser l'endpoint de reset quota
CRON_SECRET=
# NEXT_PUBLIC_BASE_URL — URL de base de l'app (http://localhost:3000 en dev)
NEXT_PUBLIC_BASE_URL=
