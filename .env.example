
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER — https://dashboard.stripe.com/products (copier Price ID du produit Starter)
STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH — https://dashboard.stripe.com/products (copier Price ID du produit Growth)
STRIPE_PRICE_GROWTH=
# STRIPE_PRICE_PRO — https://dashboard.stripe.com/products (copier Price ID du produit Pro)
STRIPE_PRICE_PRO=
# NEXT_PUBLIC_BASE_URL — Variable automatique Next.js (http://localhost:3000 en dev)
NEXT_PUBLIC_BASE_URL=