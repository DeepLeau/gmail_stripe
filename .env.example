
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_START — Prix créé dans le dashboard Stripe (format : price_xxx)
STRIPE_PRICE_START=
# STRIPE_PRICE_SCALE — Prix créé dans le dashboard Stripe (format : price_xxx)
STRIPE_PRICE_SCALE=
# STRIPE_PRICE_TEAM — Prix créé dans le dashboard Stripe (format : price_xxx)
STRIPE_PRICE_TEAM=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — Variable maison (http://localhost:3000 en dev)
NEXT_PUBLIC_BASE_URL=