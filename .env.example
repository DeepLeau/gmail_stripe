
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# STRIPE_START_PRICE_ID — https://dashboard.stripe.com/products → Start plan → Price ID
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — https://dashboard.stripe.com/products → Scale plan → Price ID
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — https://dashboard.stripe.com/products → Team plan → Price ID
STRIPE_TEAM_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — http://localhost:3000 (dev), your domain (prod)
NEXT_PUBLIC_BASE_URL=