
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks — créer un endpoint et récupérer le secret de signature
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER — Créer le produit+price dans le dashboard Stripe, copier le price ID (price_...)
STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH — Créer le produit+price dans le dashboard Stripe, copier le price ID
STRIPE_PRICE_GROWTH=
# STRIPE_PRICE_PRO — Créer le produit+price dans le dashboard Stripe, copier le price ID
STRIPE_PRICE_PRO=
# SUPABASE_SERVICE_ROLE_KEY — Dashboard Supabase > Settings > API > service_role key (NE jamais exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=