# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe
# Clé publique — utilisé côté client pour les usages futurs (Elements, etc.)
# Actuellement, le checkout se fait côté serveur via les Route Handlers API.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Clé secrète — côté serveur uniquement, NE JAMAIS exposer côté client
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# URL de base de l'application (pour les redirections Stripe)
NEXT_PUBLIC_APP_URL=http://localhost:3000
