# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ──────────────────────────────────────────────────────
# Secret key (server-only, never expose to client)
STRIPE_SECRET_KEY=
# Webhook signing secret — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# Price IDs — https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# Publishable key (exposed to client bundle, safe by design)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Base URL for Stripe success/cancel redirects
NEXT_PUBLIC_BASE_URL=http://localhost:3000
