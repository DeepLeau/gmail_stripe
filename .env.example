
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (choisir le endpoint /api/stripe/webhook après création)
STRIPE_WEBHOOK_SECRET=
# STRIPE_START_PRICE_ID — https://dashboard.stripe.com/products → créer 3 products avec pricing monthly
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — https://dashboard.stripe.com/products
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — https://dashboard.stripe.com/products
STRIPE_TEAM_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé test/public)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — localhost:3000 en dev, domaine en prod
NEXT_PUBLIC_BASE_URL=