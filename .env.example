
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (choisir le endpoint stripe)
STRIPE_WEBHOOK_SECRET=
# STRIPE_STARTER_PRICE_ID — Dashboard Stripe > Products > créer les 3 produits avec Pricing ID
STRIPE_STARTER_PRICE_ID=
# STRIPE_GROWTH_PRICE_ID — Dashboard Stripe > Products
STRIPE_GROWTH_PRICE_ID=
# STRIPE_PRO_PRICE_ID — Dashboard Stripe > Products
STRIPE_PRO_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publishable)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — =http://localhost:3000 en dev, URL de prod en prod
NEXT_PUBLIC_BASE_URL=
# SUPABASE_SERVICE_ROLE_KEY — Dashboard Supabase > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=