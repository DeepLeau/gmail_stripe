
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → choisir le endpoint →Signing secret
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER — Dashboard Stripe → Products → Starter price → API ID
STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH — Dashboard Stripe → Products → Growth price → API ID
STRIPE_PRICE_GROWTH=
# STRIPE_PRICE_PRO — Dashboard Stripe → Products → Pro price → API ID
STRIPE_PRICE_PRO=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publishable pk_live_... ou pk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=