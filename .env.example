
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publishable test/live)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_STARTER_PRICE_ID — https://dashboard.stripe.com/products (créer produit price 9€/mois)
STRIPE_STARTER_PRICE_ID=
# STRIPE_GROWTH_PRICE_ID — https://dashboard.stripe.com/products (créer produit price 29€/mois)
STRIPE_GROWTH_PRICE_ID=
# STRIPE_PRO_PRICE_ID — https://dashboard.stripe.com/products (créer produit price 79€/mois)
STRIPE_PRO_PRICE_ID=
# NEXT_PUBLIC_BASE_URL — Configuration locale (http://localhost:3000 en dev)
NEXT_PUBLIC_BASE_URL=