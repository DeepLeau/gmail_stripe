# ===========================================
# SUPABASE
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# STRIPE — Server-side secrets (NE JAMAIS préfixer NEXT_PUBLIC_)
# ===========================================
# Clé secrète Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Secret de vérification des webhooks Stripe — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# Price IDs des plans Subscription — https://dashboard.stripe.com/products
# Créer un produit Stripe pour chaque plan, puis copier le Price ID mensuel
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# ===========================================
# STRIPE — Client-side (exposés au bundle — OK par design)
# ===========================================
# Clé publishable Stripe — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# URL de base de l'application — utilisée pour success_url et cancel_url Stripe
# En prod: https://votre-domaine.com
# En local: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
