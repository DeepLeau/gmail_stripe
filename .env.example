
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (CLI : stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=
# STRIPE_START_PRICE_ID — https://dashboard.stripe.com/products (Price ID format : price_xxx)
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — https://dashboard.stripe.com/products
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — https://dashboard.stripe.com/products
STRIPE_TEAM_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — localhost:3000 en dev, domaine en prod
NEXT_PUBLIC_BASE_URL=
# SUPABASE_SERVICE_ROLE_KEY — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=