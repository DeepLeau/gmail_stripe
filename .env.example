
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_START_PRICE_ID — Create price in Stripe Dashboard: Products → Add Product → Start, 10€/mois recurring
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — Create price in Stripe Dashboard: Products → Add Product → Scale, 39€/mois recurring
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — Create price in Stripe Dashboard: Products → Add Product → Team, 79€/mois recurring
STRIPE_TEAM_PRICE_ID=
# NEXT_PUBLIC_BASE_URL — Set to your domain (e.g. https://yourapp.com) for Stripe success/cancel URLs
NEXT_PUBLIC_BASE_URL=