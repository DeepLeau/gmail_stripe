
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_START — Dashboard Stripe > Products > Prix du plan Start > ID Price
STRIPE_PRICE_START=
# STRIPE_PRICE_SCALE — Dashboard Stripe > Products > Prix du plan Scale > ID Price
STRIPE_PRICE_SCALE=
# STRIPE_PRICE_TEAM — Dashboard Stripe > Products > Prix du plan Team > ID Price
STRIPE_PRICE_TEAM=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publishable)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY — Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_APP_URL — localhost:3000 (dev), URL prod (prod)
NEXT_PUBLIC_APP_URL=