
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → select endpoint →Signing secret
STRIPE_WEBHOOK_SECRET=
# STRIPE_START_PRICE_ID — https://dashboard.stripe.com/products → price ID format price_xxxx
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — https://dashboard.stripe.com/products → price ID format price_xxxx
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — https://dashboard.stripe.com/products → price ID format price_xxxx
STRIPE_TEAM_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys → publishable test/live key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — Set to https://yourdomain.com (or http://localhost:3000 for dev)
NEXT_PUBLIC_BASE_URL=