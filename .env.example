
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# STRIPE_START_PRICE_ID — Prix dans Stripe Dashboard > Products
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — Prix dans Stripe Dashboard > Products
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — Prix dans Stripe Dashboard > Products
STRIPE_TEAM_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — URL de base de l'app (ex: http://localhost:3000 ou https://votredomaine.com)
NEXT_PUBLIC_BASE_URL=