# ─────────────────────────────────────────
# Website URL
# ─────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────
# OPENROUTER
# ─────────────────────────────────────────
OPENROUTER_API_KEY=sk_YOUR_API_KEY_HERE
NEXT_PUBLIC_APP_NAME=YourAppName

# ─────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_YOUR
NEXT_PUBLIC_STRIPE_START_PRICE_ID=price_YOUR
NEXT_PUBLIC_STRIPE_SCALE_PRICE_ID=price_YOUR
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_YOUR
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_YOUR_PUBLISHABLE_KEY_HERE
STRIPE_START_PRICE_ID=price_YOUR
STRIPE_SCALE_PRICE_ID=price_YOUR
STRIPE_ENTERPRISE_PRICE_ID=price_YOUR
STRIPE_SECRET_KEY=sk_YOUR_SECRET_KEY

# ─────────────────────────────────────────
# POSTHOG ANALYTICS
# Récupère ta clé sur https://eu.posthog.com → Project Settings → Project API Key
# Host EU par défaut (RGPD-friendly) — utilise https://us.i.posthog.com pour US
#
# RGPD : autocapture est activé par défaut. Si des utilisateurs européens sont
# concernés, ajouter un banner de consentement cookie et basculer PostHog en
# mode opt-in (capture_pageview + autocapture désactivés par défaut).
# Les inputs de formulaire sont masqués (maskAllInputs) pour éviter la capture
# accidentelle de données personnelles.
# ─────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_YOUR_PROJECT_KEY_HERE
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOK_HOST=https://eu.i.posthog.com
NODE_ENV=development

# ─────────────────────────────────────────
# RESEND — Transactional Email
# Docs : https://resend.com/docs
#
# Clé API : https://resend.com/api-keys (créer une clé avec permissions "Sending access")
# After Resend account creation, verify your sending domain:
#   https://resend.com/domains → Add Domain → add DNS records (SPF, DKIM, DMARC)
# Without a verified domain, emails only go to the Resend account owner
# and only from onboarding@resend.dev.
#
# RESEND_FROM_EMAIL:
#   Dev: onboarding@resend.dev (works without domain verification)
#   Prod: any@your-verified-domain.com (requires domain verification)
# ─────────────────────────────────────────
RESEND_API_KEY=re_YOUR_API_KEY_HERE
RESEND_FROM_EMAIL=hello@yourdomain.com

# === Variables ajoutées automatiquement par l'audit env-vars ===
# Ces variables sont utilisées dans le code mais étaient absentes
# du .env.example. Configure-les dans Vercel ou ton .env.local.
ADMIN_EMAILS=
