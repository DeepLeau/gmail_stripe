
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (choisir le bon endpoint)
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER — Dashboard Stripe > Products > Starter > Pricing tab
STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH — Dashboard Stripe > Products > Growth > Pricing tab
STRIPE_PRICE_GROWTH=
# STRIPE_PRICE_PRO — Dashboard Stripe > Products > Pro > Pricing tab
STRIPE_PRICE_PRO=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé test/publishable)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — localhost:3000 en local, URL de prod en production
NEXT_PUBLIC_BASE_URL=