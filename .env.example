
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → ajouter endpoint /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# STRIPE_STARTER_PRICE_ID — https://dashboard.stripe.com/products → créer plan Starter 9€/mois
STRIPE_STARTER_PRICE_ID=
# STRIPE_GROWTH_PRICE_ID — https://dashboard.stripe.com/products → créer plan Growth 29€/mois
STRIPE_GROWTH_PRICE_ID=
# STRIPE_PRO_PRICE_ID — https://dashboard.stripe.com/products → créer plan Pro 79€/mois
STRIPE_PRO_PRICE_ID=
# NEXT_PUBLIC_APP_URL — http://localhost:3000 en local, URL de prod en production
NEXT_PUBLIC_APP_URL=