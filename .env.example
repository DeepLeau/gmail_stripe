
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → Configure webhook endpoint /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_START — https://dashboard.stripe.com/products → Prix Start (subscription, monthly)
STRIPE_PRICE_START=
# STRIPE_PRICE_SCALE — https://dashboard.stripe.com/products → Prix Scale (subscription, monthly)
STRIPE_PRICE_SCALE=
# STRIPE_PRICE_TEAM — https://dashboard.stripe.com/products → Prix Team (subscription, monthly)
STRIPE_PRICE_TEAM=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys → Publishable key (pk_live_... ou pk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — Configuration deployment (Vercel env vars ou .env.local)
NEXT_PUBLIC_BASE_URL=