
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_ID_STARTER — Créer le produit 'Starter' dans Stripe Dashboard → Products, copier le Price ID (prix mensuel)
STRIPE_PRICE_ID_STARTER=
# STRIPE_PRICE_ID_GROWTH — Créer le produit 'Growth' dans Stripe Dashboard → Products, copier le Price ID
STRIPE_PRICE_ID_GROWTH=
# STRIPE_PRICE_ID_PRO — Créer le produit 'Pro' dans Stripe Dashboard → Products, copier le Price ID
STRIPE_PRICE_ID_PRO=
# SUPABASE_SERVICE_ROLE_KEY — Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_BASE_URL — Définir manuellement (ex: http://localhost:3000 en local, URL de prod en production)
NEXT_PUBLIC_BASE_URL=