
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (après avoir créé l'endpoint /api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_START — Dashboard Stripe → Products → Price ID du plan Start
STRIPE_PRICE_START=
# STRIPE_PRICE_SCALE — Dashboard Stripe → Products → Price ID du plan Scale
STRIPE_PRICE_SCALE=
# STRIPE_PRICE_TEAM — Dashboard Stripe → Products → Price ID du plan Team
STRIPE_PRICE_TEAM=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publishable, pas secrète)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=