
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks → CLI stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# STRIPE_START_PRICE_ID — Dashboard Stripe → Products → Start plan → Price ID (recurring)
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — Dashboard Stripe → Products → Scale plan → Price ID (recurring)
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — Dashboard Stripe → Products → Team plan → Price ID (recurring)
STRIPE_TEAM_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publique)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — http://localhost:3000 (dev) ou https://votredomaine.com (prod)
NEXT_PUBLIC_BASE_URL=