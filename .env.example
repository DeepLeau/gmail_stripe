# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_START_PRICE_ID=
NEXT_PUBLIC_STRIPE_SCALE_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PostHog Analytics
# Client-side key (safe to expose in the browser bundle)
NEXT_PUBLIC_POSTHOG_KEY=
# Server-side host — EU region or https://app.posthog.com for US
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
# Server-side API key for server-side capture events (e.g. checkout_created)
# Keep this secret — do NOT prefix with NEXT_PUBLIC_
POSTHOG_API_KEY=
