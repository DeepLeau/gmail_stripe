
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# STRIPE_START_PRICE_ID — Créer un produit Price dans le dashboard Stripe pour le plan Start (9,99€/mois, récurrent)
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — Créer un produit Price dans le dashboard Stripe pour le plan Scale (29,99€/mois, récurrent)
STRIPE_SCALE_PRICE_ID=
# STRIPE_ENTERPRISE_PRICE_ID — Créer un produit Price dans le dashboard Stripe pour le plan Enterprise (99,99€/mois, récurrent)
STRIPE_ENTERPRISE_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publishable, pas secret)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — URL de base de l'app (ex: http://localhost:3000 en dev, ton domaine en prod)
NEXT_PUBLIC_BASE_URL=