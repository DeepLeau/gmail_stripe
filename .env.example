
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_START — https://dashboard.stripe.com/prices — créer price pour plan Start (10€/mois, EUR, recurring monthly)
STRIPE_PRICE_START=
# STRIPE_PRICE_SCALE — https://dashboard.stripe.com/prices — créer price pour plan Scale (39€/mois, EUR, recurring monthly)
STRIPE_PRICE_SCALE=
# STRIPE_PRICE_TEAM — https://dashboard.stripe.com/prices — créer price pour plan Team (79€/mois, EUR, recurring monthly)
STRIPE_PRICE_TEAM=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publishable, pas secrète)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_APP_URL — URL de l'app, ex: https://yourapp.vercel.app (utilisé pour successUrl et cancelUrl)
NEXT_PUBLIC_APP_URL=