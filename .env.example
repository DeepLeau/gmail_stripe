
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (lancer un webhook local pour générer)
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER — Créer un produit+price dans le dashboard Stripe, copier le price_id (prix: 9€/mois)
STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH — Créer un produit+price dans le dashboard Stripe, copier le price_id (prix: 29€/mois)
STRIPE_PRICE_GROWTH=
# STRIPE_PRICE_PRO — Créer un produit+price dans le dashboard Stripe, copier le price_id (prix: 79€/mois)
STRIPE_PRICE_PRO=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé PUBLISHABLE, pas secret)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — http://localhost:3000 en local, URL de prod en production
NEXT_PUBLIC_BASE_URL=