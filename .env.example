
# Stripe — configuration paiement
# STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET — https://dashboard.stripe.com/webhooks (choisir endpoint /api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=
# STRIPE_START_PRICE_ID — https://dashboard.stripe.com/products (créer prix pour plan Start 9€/mois)
STRIPE_START_PRICE_ID=
# STRIPE_SCALE_PRICE_ID — https://dashboard.stripe.com/products (créer prix pour plan Scale 29€/mois)
STRIPE_SCALE_PRICE_ID=
# STRIPE_TEAM_PRICE_ID — https://dashboard.stripe.com/products (créer prix pour plan Team 59€/mois)
STRIPE_TEAM_PRICE_ID=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — https://dashboard.stripe.com/apikeys (clé publique)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_BASE_URL — https://dashboard.vercel.com (ou localhost:3000 en dev)
NEXT_PUBLIC_BASE_URL=